#!/bin/sh
set -eu

set -- ${PYTHON_BIN:-python3}
if ! command -v "$1" >/dev/null 2>&1; then
  echo "error: PYTHON_BIN command is required for the frtb-capital agent worktree guard" >&2
  exit 1
fi

"$@" scripts/agent_worktree.py guard --quiet
"$@" scripts/ci/check_code_drift.py --quiet
"$@" scripts/ci/check_code_drift.py --changed --quiet
"$@" scripts/ci/check_test_value.py --quiet
"$@" scripts/ci/check_dead_code.py --quiet
